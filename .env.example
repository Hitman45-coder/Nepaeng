# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://nepaeng:nepaeng@localhost:5432/nepaeng_platform?schema=public"

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Generate a strong secret, e.g.  openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"
# Lifetime of an authenticated session, in seconds (default 8h).
SESSION_TTL_SECONDS="28800"

# Seed admin bootstrap (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="director@nepaeng.com.au"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# ---------------------------------------------------------------------------
# MYOB AccountRight / Business API (OAuth2)
# https://developer.myob.com/api/myob-business-api/
# ---------------------------------------------------------------------------
MYOB_CLIENT_ID=""
MYOB_CLIENT_SECRET=""
MYOB_REDIRECT_URI="http://localhost:3000/api/myob/callback"
# Developer API key (x-myobapi-key header)
MYOB_API_KEY=""
# Set to "true" to enable the node-cron payment-status poller.
MYOB_POLL_ENABLED="false"
# Cron expression for polling MYOB invoice/payment status (default: every 15 min).
MYOB_POLL_CRON="*/15 * * * *"

# App base URL (used for absolute links / OAuth flows)
APP_BASE_URL="http://localhost:3000"
